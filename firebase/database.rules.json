{
  "rules": {
    ".read": true,
    ".write": false,
    "heartRate": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isNumber() && newData.val() >= 20 && newData.val() <= 240"
    },
    "timestamp": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isNumber()"
    },
    "sampleTimestamp": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isNumber()"
    },
    "online": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isBoolean()"
    },
    "history": {
      ".read": true,
      "$timestamp": {
        ".write": true,
        ".validate": "!newData.exists() || (newData.hasChildren(['heartRate', 'timestamp', 'sampleTimestamp']) && newData.child('heartRate').isNumber() && newData.child('heartRate').val() >= 20 && newData.child('heartRate').val() <= 240 && newData.child('timestamp').isNumber() && newData.child('sampleTimestamp').isNumber())"
      }
    }
  }
}
